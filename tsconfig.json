{
	"compilerOptions": {
		"esModuleInterop": true,
		"jsx": "react-jsx",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["./src/**/*", "*.ts", "*.js"],
	"exclude": ["./src/**/*.spec.ts"]
}
